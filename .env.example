# OpenClaw Workspace 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# cp .env.example .env

# ==========================================
# 必需配置
# ==========================================

# Tavily Search API Key (实时搜索)
# 获取地址：https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ==========================================
# 可选配置 - 邮件技能 (skills/imap-smtp-email)
# ==========================================

# IMAP 配置（接收邮件）
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_app_password
IMAP_TLS=true
IMAP_REJECT_UNAUTHORIZED=true
IMAP_MAILBOX=INBOX

# SMTP 配置（发送邮件）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_REJECT_UNAUTHORIZED=true

# ==========================================
# 可选配置 - 腾讯云 ASR (skills/chinese-asr)
# ==========================================
# 也可以在 skills/chinese-asr/config.json 中配置
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key

# ==========================================
# OpenClaw 配置
# ==========================================
# 查看所有配置：openclaw config list
# 设置配置：openclaw config set <key> <value>

# 默认模型
# OPENCLAW_DEFAULT_MODEL=moonshot/kimi-k2.5

# Gateway 端口
# OPENCLAW_GATEWAY_PORT=18789
