        {
          "key": "BRAVE_API_KEY",
          "name": "Brave Search API Key",
          "description": "依赖 search 技能，需配置 BRAVE_API_KEY",
          "required": true,
          "checkType": "file",
          "filePath": "~/.openclaw/workspace/.env",
          "pattern": "BRAVE_API_KEY",
          "setupCommand": "在 ~/.openclaw/workspace/.env 中配置 BRAVE_API_KEY=<your-key>"
        }
      ]
    },
    "dueros-evokehome": {
      "name": "DuerOS 智能家居",
      "description": "小度智能家居控制",
      "configs": [
        {
          "key": "DUEROS_ACCESS_TOKEN",
          "name": "DuerOS Access Token",
          "description": "小度智能家居访问令牌，需从小度官网开发者工具获取",
          "required": true,
          "checkType": "file",
          "filePath": "~/.openclaw/workspace/.env",
          "pattern": "DUEROS_ACCESS_TOKEN",
          "setupCommand": "在 ~/.openclaw/workspace/.env 中配置 DUEROS_ACCESS_TOKEN=<token>"
