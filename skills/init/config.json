{
  "requiredSkills": [
    "summarize-pro"
  ],
  "skillConfigs": {
    "search": {
      "name": "网络搜索",
      "description": "Brave Search API 网络搜索",
      "configs": [
        {
          "key": "BRAVE_API_KEY",
          "name": "Brave Search API Key",
          "description": "用于网页搜索，可从 https://brave.com/search/api/ 获取免费额度",
          "required": true,
          "checkType": "file",
          "filePath": "~/.openclaw/workspace/.env",
          "pattern": "BRAVE_API_KEY",
          "setupCommand": "在 ~/.openclaw/workspace/.env 中配置 BRAVE_API_KEY=<your-key>"
        }
      ]
    },
    "tavily-search": {
      "name": "Tavily 搜索",
      "description": "AI 优化的网络搜索",
      "configs": [
        {
          "key": "TAVILY_API_KEY",
          "name": "Tavily API Key",
          "description": "用于 Tavily 搜索，可从 https://tavily.com 获取",
          "required": true,
          "checkType": "file",
          "filePath": "~/.openclaw/workspace/.env",
          "pattern": "TAVILY_API_KEY",
          "setupCommand": "在 ~/.openclaw/workspace/.env 中配置 TAVILY_API_KEY=<your-key>"
        }
      ]
    },
    "super-websearch-realtime": {
      "name": "超级实时搜索",
